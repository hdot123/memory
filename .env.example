# ============================================================
# memory-core 环境变量配置示例
# 复制此文件为 .env 并根据需要修改
# ============================================================

# ============================================================
# Hook 系统配置
# ============================================================

# 是否禁用 hook（设置为 1 禁用）
# MEMORY_HOOK_DISABLED=0

# 是否启用强制 hook 模式
# MEMORY_HOOK_FORCE=0

# Hook 指标是否禁用（设置为 1 禁用指标收集）
# MEMORY_HOOK_METRICS_DISABLED=0

# Hook 指标文件路径
# MEMORY_HOOK_METRICS_PATH=~/.memory-core/metrics.jsonl

# 业务项目黑名单（逗号分隔的目录路径）
# MEMORY_HOOK_DENY_PROJECT_ROOTS=

# ============================================================
# 内存核心配置
# ============================================================

# 绕过 denylist 检查（开发调试用）
# MEMORY_CORE_BYPASS_DENYLIST=0

# 启用 OpenTelemetry（设置为 1 启用）
# MEMORY_OTEL_ENABLED=0

# ============================================================
# 遥测配置（PostHog）
# ============================================================

# PostHog API Key（留空或注释掉则禁用遥测）
# POSTHOG_API_KEY=

# PostHog Host（默认 https://us.posthog.com）
# POSTHOG_HOST=https://us.posthog.com

# ============================================================
# 集成配置
# ============================================================

# Linear API Key（用于 Linear 集成）
LINEAR_API_KEY=

# 飞书通知 Chat ID（用于 daily_kb_audit 通知）
LARK_AUDIT_CHAT_ID=

# ============================================================
# 调试配置
# ============================================================

# Schema 审计日志路径
# MEMORY_SCHEMA_AUDIT_LOG=

# 是否启用 shadow run 模式（只读不写）
# MEMORY_HOOK_SHADOW_RUN=0

# 是否记录项目生命周期
# MEMORY_HOOK_RECORD_PROJECT_LIFECYCLE=1
